{
  "name": "stackscope",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/serve-static.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bash scripts/run-e2e.sh",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:e2e"
  },
  "dependencies": {
    "@xyflow/react": "12.11.2",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "typescript": "^5",
    "vitest": "4.1.10"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    }
  }
}
